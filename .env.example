DB_NAME=retro
DB_USER=retro
DB_PASSWORD=change-me
DB_ROOT_PASSWORD=change-me-too

# Auth for the API + GUI. Leave both blank to run open (local dev).
# Set them to require credentials; the MCP server and tools send the same ones.
# The browser logs in with these (cookie session); the API/tools use HTTP Basic.
RHDB_AUTH_USER=
RHDB_AUTH_PASSWORD=

# Secret that signs the browser login cookie. Generate: openssl rand -hex 32
# If blank, it is derived from the auth credentials.
RHDB_SECRET_KEY=

# Public base URL the label QR codes encode (resolves via /items/<asset_id>).
RHDB_BASE_URL=https://db.2600.me
